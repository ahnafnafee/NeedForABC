# Auto detect text files and perform LF normalization
* text=auto
Library/Artifacts/* filter=lfs diff=lfs merge=lfs -text
Library/Artifacts/35/* filter=lfs diff=lfs merge=lfs -text
Library/Artifacts/5f/* filter=lfs diff=lfs merge=lfs -text
Library/Artifacts/64/* filter=lfs diff=lfs merge=lfs -text
Library/Artifacts/cd/* filter=lfs diff=lfs merge=lfs -text
